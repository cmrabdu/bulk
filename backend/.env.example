# Copier en `.env` sur le serveur et remplir. NE PAS committer le .env réel.

# Secret de signature des cookies de session (générer : openssl rand -hex 32)
SESSION_SECRET=change-me-openssl-rand-hex-32

# Identifiants de connexion (mono-utilisateur)
APP_USERNAME=abdullah
APP_PASSWORD=change-me

# Le reste est surchargé par docker-compose en prod :
# ENV=production
# DATABASE_URL=sqlite:////app/data/bulk.db
# COOKIE_SECURE=true
# TZ=Europe/Paris
